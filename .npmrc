# プロキシ設定 — npm 用
#
# HTTP_PROXY / HTTPS_PROXY / NO_PROXY 環境変数を設定してから
# npm install を実行するだけで自動的に使われます。
# このファイルはリポジトリ内のすべての npm プロジェクト（docusaurus / astro / eleventy）に適用されます。
#
# 【使い方】
#   export HTTP_PROXY=http://proxy.company.com:8080
#   export HTTPS_PROXY=http://proxy.company.com:8080
#   export NO_PROXY=localhost,127.0.0.1
#   cd docusaurus && npm install
#
# 環境変数が未設定の場合は空文字列になり、プロキシなしで動作します。

proxy=${HTTP_PROXY}
https-proxy=${HTTPS_PROXY}
noproxy=${NO_PROXY}
