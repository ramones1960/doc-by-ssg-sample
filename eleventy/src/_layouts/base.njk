<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} — プロジェクト X</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="sidebar">
    <div class="sidebar-header">
      <h1><a href="/">プロジェクト X</a></h1>
      <small>社内文書ポータル</small>
    </div>
    <ul class="nav-list">
      <li><a href="/">プロジェクト概要</a></li>
      <li><a href="/docs/getting-started/">開発ガイド</a></li>
      <li><a href="/docs/api-reference/">API リファレンス</a></li>
      <li class="nav-section">議事録</li>
      <li class="nav-sub"><a href="/docs/meeting-notes/2025-06/">2025 年 6 月</a></li>
    </ul>
  </nav>
  <main class="content">
    <article>
      {{ content | safe }}
    </article>
    <footer>
      <p>社内限定 — プロジェクト X 開発チーム</p>
    </footer>
  </main>

  <!-- Mermaid: ```mermaid コードブロックをクライアント側で図に変換する -->
  <script type="module">
    import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";
    document.querySelectorAll("pre code.language-mermaid").forEach((code) => {
      const div = document.createElement("div");
      div.className = "mermaid";
      div.textContent = code.textContent;
      code.parentElement.replaceWith(div);
    });
    mermaid.initialize({ startOnLoad: false });
    await mermaid.run();
  </script>
</body>
</html>
