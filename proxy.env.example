# プロキシ設定テンプレート
#
# このファイルをコピーして実際の値を設定し、シェルで source してください。
#
#   cp proxy.env.example proxy.env
#   # proxy.env を編集してプロキシ情報を記入
#   source proxy.env
#
# proxy.env は .gitignore に含まれているのでコミットされません。

# ─── 全パッケージ管理ツール共通 ─────────────────────────────────────
# pip / npm / Go のすべてがこれらの環境変数を自動参照します

export HTTP_PROXY=http://proxy.company.com:8080
export HTTPS_PROXY=http://proxy.company.com:8080

# プロキシを経由しないホスト（カンマ区切り）
# SSG のビルド成果物は localhost でアクセスするため localhost を除外しておく
export NO_PROXY=localhost,127.0.0.1,.company.com

# ─── npm（Docusaurus / Astro / Eleventy）───────────────────────────────
# リポジトリルートの .npmrc が ${HTTP_PROXY} / ${HTTPS_PROXY} / ${NO_PROXY} を
# 参照するため、上記の export だけで npm install が通ります。
# 追加設定は不要です。

# ─── pip（MkDocs / Sphinx）─────────────────────────────────────────────
# pip は HTTP_PROXY / HTTPS_PROXY を自動で読むため追加設定は不要です。
# 社内 CA 証明書を pip に信頼させる場合は以下を設定してください。
# export PIP_CERT=/path/to/company-ca-bundle.crt
# または pip.conf.example を参照してください。

# ─── Go（Hugo バイナリのインストール）───────────────────────────────────
# go install で Hugo を取得する際、上記 HTTP_PROXY / HTTPS_PROXY が自動適用されます。
# Go モジュールプロキシを社内ミラーに向けたい場合のみ以下を設定してください。
# export GOPROXY=https://goproxy.company.com,direct
# export GONOSUMDB=*
